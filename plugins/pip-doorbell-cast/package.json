{
  "name": "@scrypted/pip-doorbell-cast",
  "private": true,
  "version": "0.1.0",
  "description": "Picture-in-Picture doorbell cast — instantly pushes live Blink/Ring doorbell video to Fire TV, Chromecast, Vizio, and Alexa Show displays.",
  "scripts": {
    "scrypted-setup-project": "scrypted-setup-project",
    "prescrypted-setup-project": "scrypted-package-json",
    "build": "scrypted-webpack",
    "prepublishOnly": "NODE_ENV=production scrypted-webpack",
    "scrypted-deploy": "scrypted-deploy"
  },
  "keywords": [
    "scrypted",
    "plugin",
    "pip",
    "doorbell",
    "cast",
    "firetv",
    "chromecast"
  ],
  "scrypted": {
    "name": "PiP Doorbell Cast",
    "type": "DeviceProvider",
    "interfaces": [
      "DeviceProvider",
      "Settings",
      "MixinProvider"
    ],
    "babel": true,
    "pluginDependencies": [
      "@scrypted/blink",
      "@scrypted/ring",
      "@scrypted/chromecast"
    ]
  },
  "dependencies": {
    "@scrypted/common": "file:../../common",
    "@scrypted/sdk": "^0.3.61",
    "@types/node": "^18.15.11",
    "adbkit": "^3.2.6"
  }
}
